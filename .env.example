# ─── Modo Mock (teste sem API real) ───────────────────────────────────────────
# true  → simula postagens (não chama o Twitter, ideal para testar o painel)
# false → postagem real (precisa das credenciais abaixo)
MOCK_MODE=true

# ─── X (Twitter) API Credentials ─────────────────────────────────────────────
# Gere em: https://developer.twitter.com/en/portal/dashboard
# Necessário: app com permissão de Read + Write
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ─── Web Panel ────────────────────────────────────────────────────────────────
PANEL_PASSWORD=
SESSION_SECRET=

# Porta do painel web (default: 3000)
PORT=3000

# ─── Agendamento ──────────────────────────────────────────────────────────────
# Cron schedule — padrão: todo dia às 9h (horário do servidor)
# Formato: minuto hora dia mês dia-da-semana
# Exemplos:
#   0 9 * * *   → 9h todo dia
#   0 12 * * *  → 12h todo dia
#   30 18 * * * → 18h30 todo dia
CRON_SCHEDULE=0 9 * * *
